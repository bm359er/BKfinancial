            color: #374151;
            margin-bottom: 1.5rem;
            text-align: justify;
        }

        .article-content h2 {
            color: var(--primary);
            font-size: 1.75rem;
            margin: 2.5rem 0 1rem 0;
        }

        .article-content blockquote {
            background-color: var(--bg-light);
            border-left: 4px solid var(--secondary);
            padding: 1rem 1.5rem;
            margin: 2rem 0;
            font-style: italic;
            color: #4b5563;
